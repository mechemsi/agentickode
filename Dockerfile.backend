FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl docker.io nodejs npm openssh-client pipx tmux unzip && \
    rm -rf /var/lib/apt/lists/* && \
    curl -fsSL https://bun.sh/install | bash

WORKDIR /app
ENV PYTHONPATH=/app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install AI agents for the chat feature
# Override with --build-arg INSTALL_AGENTS="claude codex" for selective install
ARG INSTALL_AGENTS="claude codex gemini aider opencode"
COPY scripts/install-agents.sh /tmp/install-agents.sh
RUN chmod +x /tmp/install-agents.sh && \
    /tmp/install-agents.sh $INSTALL_AGENTS || true && \
    rm /tmp/install-agents.sh

# Stash installed agents so entrypoint can seed an empty volume
RUN cp -a /root/.local /root/.local-seed

ENV PATH="/root/.local/bin:/root/.local/share/claude/bin:/root/.bun/bin:${PATH}"

COPY alembic.ini .
COPY alembic/ ./alembic/
COPY backend/ ./backend/

EXPOSE 8000

COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

CMD ["/docker-entrypoint.sh"]
