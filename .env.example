# Database
DATABASE_URL=postgresql+asyncpg://agentickode:agentickode@postgres:5432/agentickode

# Ollama
OLLAMA_URL=http://localhost:11434

# OpenHands
OPENHANDS_URL=http://localhost:3000

# ChromaDB
CHROMADB_URL=http://localhost:8000
CHROMADB_TOKEN=

# Gitea
GITEA_URL=https://gitea.yourdomain.com
GITEA_TOKEN=

# GitHub
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com

# Bitbucket (workspace/repo access token from repo/workspace settings → Access tokens)
BITBUCKET_ACCESS_TOKEN=
BITBUCKET_BASE_URL=https://api.bitbucket.org

# GitLab
GITLAB_TOKEN=
GITLAB_API_URL=https://gitlab.com

# Workspace
WORKSPACE_ROOT=/workspaces
DEFAULT_SSH_KEY_PATH=/app/.ssh/id_ed25519
SANDBOX_TEMPLATES_PATH=/opt/agentickode/docker/sandboxes

# Encryption (for backup/export and project secrets)
ENCRYPTION_KEY=

# App
APP_BASE_URL=http://localhost:5173

# Worker
MAX_CONCURRENT_RUNS=3
POLL_INTERVAL_SECONDS=2
APPROVAL_TIMEOUT_HOURS=24
PHASE_DELAY_SECONDS=10

# LLM Models
PLANNER_MODEL=qwen2.5-coder:32b-instruct-q4_K_M
CODER_MODEL=devstral:24b-q5_K_M
REVIEWER_MODEL=qwen2.5-coder:14b-instruct-q5_K_M
FAST_MODEL=qwen3:30b-a3b
